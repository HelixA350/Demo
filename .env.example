# OpenAI
OPENAI_API_KEY=sk-zvSA71yGDHlFevQofEFtDbXyCi3RUjaiP2Ey3PQemH64CcTR
# Базовый URL для использования совместимых
OPENAI_BASE_URL=https://neuroapi.host/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_WHISPER_MODEL=whisper-1
# Максимальное число токенов в ответе LLM
OPENAI_MAX_TOKENS=1024

# Database
# Для Docker Compose: хост — имя сервиса "db"
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/consultant
# Для локального запуска без Docker:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/consultant

# Redis
# Для Docker Compose: хост — имя сервиса "redis"
REDIS_URL=redis://redis:6379/0
# Для локального запуска:
# REDIS_URL=redis://localhost:6379/0

# TTL авторизационного кэша в секундах
AUTH_CACHE_TTL=900

# Security
# Случайная строка
SECRET_KEY=super-secret-key

# App
VECTORSTORE_PATH=./vectorstore
DOCUMENT_PATH=./data/document.pdf
# Количество последних пар сообщений, хранимых в истории диалога
MEMORY_WINDOW_SIZE=5

# PostgreSQL (используется docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=consultant
